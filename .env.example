# ── PostGIS ────────────────────────────────────────────────────────────────────
POSTGRES_DB=gridtokenx_geo
POSTGRES_USER=gridtokenx
POSTGRES_PASSWORD=gridtokenx_pass

# Connection URL (used by load_postgis.py and the API service)
POSTGIS_URL=postgresql://gridtokenx:gridtokenx_pass@localhost:5432/gridtokenx_geo

# ── LLM Cognitive Layer ────────────────────────────────────────────────────────
# Used by agent/gemma_client.py (Gemma 4 Flash via Gemini API)
GEMINI_API_KEY=your_gemini_api_key_here

# ── MLOps ──────────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=sqlite:///mlflow.db
